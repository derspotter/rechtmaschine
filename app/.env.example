# OpenAI API Key for document classification
OPENAI_API_KEY=your_openai_api_key_here

# Optional: route non-search OpenAI Responses API calls through Azure OpenAI.
# Keep ChatGPT Search on native OpenAI unless you explicitly accept Azure Bing grounding terms.
# OPENAI_PROVIDER=azure
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here
# AZURE_OPENAI_BASE_URL=https://rechtmaschine.openai.azure.com/openai/v1/
# If Azure deployment names differ from public model IDs, map them here:
# AZURE_OPENAI_MODEL_MAP={"gpt-5.5":"your-gpt-55-deployment","gpt-5.2":"your-gpt-52-deployment"}
# Or use per-model vars:
# AZURE_OPENAI_DEPLOYMENT_GPT_5_5=your-gpt-55-deployment
# Azure file upload support can differ from native OpenAI. Default is off, so PDFs are text-extracted inline.
# AZURE_OPENAI_ENABLE_FILE_UPLOADS=false

# Optional semantic page-only citation judge via service_manager/Ollama.
# Used after deterministic citation checks for ambiguous/not_found/wrong-page findings.
# CITATION_QWEN_VERIFICATION_ENABLED=true
# CITATION_QWEN_MODEL=qwen3.6:27b-q4_K_M
# CITATION_QWEN_MAX_CHECKS=40
# CITATION_QWEN_PAGE_CHAR_LIMIT=12000
# CITATION_QWEN_NUM_CTX=32768
# CITATION_QWEN_TIMEOUT_SEC=300

# Optional Qwen logical segmentation for uploaded/OCR documents.
# Used by POST /documents/{document_id}/segment. Skips one-page files and court decisions.
# DOCUMENT_SEGMENTATION_ENABLED=true
# DOCUMENT_SEGMENTATION_MODEL=qwen3.6:27b-q4_K_M
# DOCUMENT_SEGMENTATION_PAGE_CHAR_LIMIT=26000
# DOCUMENT_SEGMENTATION_NUM_PREDICT=3600

# Distributed GPU services.
# Keep one pullable codebase on all machines; assign machine roles via env.
#
# Server/app host:
# - OCR_SERVICE_URL points to the RTX 3060 OCR manager.
# - ANONYMIZATION_SERVICE_URL points to the Qwen/anonymization manager.
# - Role-specific health/start vars let the app wake/start the correct machine.
#
# OCR worker host:
# - SERVICE_MANAGER_ROLE=ocr
# - SERVICE_MANAGER_PORT=8004
# - run: python service_manager.py
#
# Qwen/anonymization worker host:
# - SERVICE_MANAGER_ROLE=anonymization
# - SERVICE_MANAGER_PORT=8002
# - run: python service_manager.py
OCR_SERVICE_URL=http://100.x.x.x:8004
OCR_API_KEY=your_ocr_api_key_here
OCR_SERVICE_MANAGER_HEALTH_URL=http://100.x.x.x:8004/health
OCR_SERVICE_MANAGER_SSH_HOST=ocr-desktop
OCR_SERVICE_MANAGER_SSH_USER=your_ssh_user
OCR_SERVICE_MANAGER_START_CMD='cd /path/to/rechtmaschine && source .venv/bin/activate && SERVICE_MANAGER_ROLE=ocr SERVICE_MANAGER_PORT=8004 python service_manager.py'

ANONYMIZATION_SERVICE_URL=http://100.106.140.46:8002
ANONYMIZATION_API_KEY=your_anonymization_api_key_here
ANONYMIZATION_SERVICE_MANAGER_HEALTH_URL=http://100.106.140.46:8002/health
ANONYMIZATION_SERVICE_MANAGER_SSH_HOST=desktop
ANONYMIZATION_SERVICE_MANAGER_SSH_USER=your_ssh_user
ANONYMIZATION_SERVICE_MANAGER_START_CMD='cd /path/to/rechtmaschine && source .venv/bin/activate && SERVICE_MANAGER_ROLE=anonymization SERVICE_MANAGER_PORT=8002 python service_manager.py'

# Case memory: automatic reflection + local Qwen extraction.
# Extraction defaults to the local llama-server Qwen on desktop; set a
# gemini-* model to use the cloud path instead.
# MEMORY_EXTRACTION_MODEL=qwen3.6-27b-udq5xl-vision
# MEMORY_EXTRACTION_NUM_CTX=32768
# MAX_MEMORY_SOURCE_CHARS=60000
# MEMORY_MAX_ITEMS_PER_FIELD=3
# MEMORY_MAX_OPS_PER_PROPOSAL=8
# MEMORY_CONSOLIDATE_THRESHOLD=10
# MEMORY_CONSOLIDATE_COOLDOWN_HOURS=6
# Max j-lawyer documents folded per "Akte lesen" run (trigger=jlawyer rolling
# fold into one proposal); a typical Akte fits one pass at the default:
# MEMORY_JLAWYER_MAX_DOCS=40
# Full-state passes (jlawyer fold merge, consolidate) emit the complete memory
# as JSON; too small a budget truncates it (done_reason=length) -> invalid JSON.
# MEMORY_FULLSTATE_NUM_PREDICT=8000
# Retry transient Qwen unreachability (service-manager cycled mid-fold):
# MEMORY_QWEN_RETRIES=3
# MEMORY_QWEN_RETRY_BACKOFF=3
# Case context (memory + chronological Akte excerpts) given to the extractor:
# MEMORY_CONTEXT_TOTAL_CHARS=20000
# MEMORY_CONTEXT_DOC_CHARS=4000
# Auto-queue reflection jobs when documents are OCR'd, drafts are saved, or
# queries complete (processed by the job worker; merged + debounced per case).
# MEMORY_AUTO_REFLECT_ENABLED=true
# MEMORY_REFLECT_DEBOUNCE_SEC=60
# Auto-accept reflection proposals instead of leaving them pending for review.
# MEMORY_AUTO_APPLY=false
# Cross-case pattern wiki: anonymized, reviewed entries injected into
# generation/query prompts when their tags match the case memory.
# PATTERN_WIKI_INJECT_ENABLED=true
# PATTERN_WIKI_MAX_INJECTED=3
# PATTERN_WIKI_INJECT_MAX_CHARS=4000
# PATTERN_WIKI_MIN_TAG_MATCHES=2
# Freshness-gated jurisprudence packs (Phase 9): recent case-law injected into
# generation/query prompts; stale/thin/missing packs enqueue background research.
# JURIS_PACK_INJECT_ENABLED=true
# JURIS_PACK_AUTO_RESEARCH=true
# JURIS_PACK_MAX_DECISIONS=5
# JURIS_PACK_MIN_DECISIONS=2
# JURIS_MAX_AGE_URGENT_DAYS=7
# JURIS_MAX_AGE_NORMAL_DAYS=30
# JURIS_MAX_AGE_EVERGREEN_DAYS=180
# JURIS_RESEARCH_COOLDOWN_HOURS=24

# OCR text-layer embedding: PDFs that need OCR are processed via the worker's
# /ocr-pdf endpoint (ocrmypdf + local PaddleOCR plugin) and replaced in place
# with a searchable version; original kept as <name>.orig.pdf.
# OCR_EMBED_PDF_ENABLED=true
# OCR_EMBED_PDF_TIMEOUT_SEC=1500
# Worker side: OCRMYPDF_PYTHON=/path/to/ocr/.venv_hpi/bin/python, OCR_PDF_TIMEOUT_SEC=1500
# Worker side: SLEEP_INHIBIT_WHILE_BUSY=true blocks suspend while the queue is active

# Document classification backend: local Qwen vision (default) or gemini.
# CLASSIFICATION_BACKEND=qwen

# Cross-case RAG retrieval: the Debian RAG API (rag/docker-compose.debian.yml).
# RAG_SERVICE_URL=http://debian:8090
# RAG_SERVICE_API_KEY=<shared secret, must match RAG_SERVICE_API_KEY in debian rag/.env.debian>

# Cross-case RAG retrieval in generation/query (consumer of the debian store).
# Off until the store is filled; flip to true after the bulk ingest.
# RAG_RETRIEVAL_ENABLED=true
# RAG_COLLECTION=kanzlei          # must match ingest_runner --collection
# RAG_RETRIEVAL_LIMIT=6           # chunks injected per prompt

# Statutory ground-truth injection in generation/query (local legal_texts lookup).
# On by default; statutes refreshed from bundestag/gesetze via legal_texts.downloader.
# LEGAL_GROUNDING_ENABLED=true
