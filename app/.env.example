# OpenAI API Key for document classification
OPENAI_API_KEY=your_openai_api_key_here

# Optional: route non-search OpenAI Responses API calls through Azure OpenAI.
# Keep ChatGPT Search on native OpenAI unless you explicitly accept Azure Bing grounding terms.
# OPENAI_PROVIDER=azure
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here
# AZURE_OPENAI_BASE_URL=https://rechtmaschine.openai.azure.com/openai/v1/
# If Azure deployment names differ from public model IDs, map them here:
# AZURE_OPENAI_MODEL_MAP={"gpt-5.5":"your-gpt-55-deployment","gpt-5.2":"your-gpt-52-deployment"}
# Or use per-model vars:
# AZURE_OPENAI_DEPLOYMENT_GPT_5_5=your-gpt-55-deployment
# Azure file upload support can differ from native OpenAI. Default is off, so PDFs are text-extracted inline.
# AZURE_OPENAI_ENABLE_FILE_UPLOADS=false

# Optional semantic page-only citation judge via service_manager/Ollama.
# Used after deterministic citation checks for ambiguous/not_found/wrong-page findings.
# CITATION_QWEN_VERIFICATION_ENABLED=true
# CITATION_QWEN_MODEL=qwen3.6:27b-q4_K_M
# CITATION_QWEN_MAX_CHECKS=40
# CITATION_QWEN_PAGE_CHAR_LIMIT=12000
# CITATION_QWEN_NUM_CTX=32768
# CITATION_QWEN_TIMEOUT_SEC=300

# Optional Qwen logical segmentation for uploaded/OCR documents.
# Used by POST /documents/{document_id}/segment. Skips one-page files and court decisions.
# DOCUMENT_SEGMENTATION_ENABLED=true
# DOCUMENT_SEGMENTATION_MODEL=qwen3.6:27b-q4_K_M
# DOCUMENT_SEGMENTATION_PAGE_CHAR_LIMIT=26000
# DOCUMENT_SEGMENTATION_NUM_PREDICT=3600

# Anonymization Service (via Tailscale to home PC)
# Home PC Tailscale IP: 100.106.140.46, Service Port: 8002
ANONYMIZATION_SERVICE_URL=http://100.106.140.46:8002
ANONYMIZATION_API_KEY=your_anonymization_api_key_here
